                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost/api/v1/bookings/my?page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "path": ["api", "v1", "bookings", "my"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
