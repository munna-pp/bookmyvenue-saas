            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"venueId\": \"6a3fa0e90dc0b359f82ee59d\",\n  \"eventType\": \"wedding\",\n  \"eventDate\": \"2026-07-20\",\n  \"startTime\": \"12:00\",\n  \"endTime\": \"17:00\",\n  \"guestCount\": 150,\n  \"specialRequests\": \"Need red carpets at ballroom entryway.\"\n}"
            },
            "url": {
              "raw": "http://localhost/api/v1/bookings",
              "protocol": "http",
              "host": ["localhost"],
              "path": ["api", "v1", "bookings"]
            }
          }
        },
