# ==============================================================================
# BookMyVenue - Local Environment Variables Template
# Copy this file to '.env' and modify for local development.
# ==============================================================================

# Backend express port and Node environment
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379

# JWT Configurations (use long cryptographically secure random values in prod)
JWT_SECRET=dev-jwt-secret-key-should-be-long-and-secure
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-key-should-be-long-and-secure

# Cloudinary - Storage Service (Placeholder)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay - Payment Service (Placeholder)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
